LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=3

EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANK_MODEL_NAME=BAAI/bge-reranker-base
RERANK_THRESHOLD=0.55
VECTOR_CANDIDATE_MULTIPLIER=4
VECTOR_CANDIDATE_MIN=20
ENABLE_BM25=true
BM25_TOP_K=20

# Set this in production. Requests must send: X-API-Key: <value>
API_KEY=

# Comma-separated origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

MAX_UPLOAD_MB=20
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
